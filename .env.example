# Checkmk-Verbindung (optional – ohne diese Angaben werden Mock-Daten verwendet)
CMK_URL=https://checkmk-server/mysite
CMK_USER=automation
CMK_SECRET=your-automation-secret
# TLS-Zertifikatsprüfung für CMK-REST-Aufrufe (true empfohlen bei gültigem Zertifikat)
CMK_SSL_VERIFY=false

# Speicherpfad für den Graph (Standard: saved_graph.json)
SAVE_FILE=/app/data/saved_graph.json
